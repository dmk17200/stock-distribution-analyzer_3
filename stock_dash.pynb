{"cells":[{"cell_type":"code","source":"import pandas as _hex_pandas\nimport datetime as _hex_datetime\nimport json as _hex_json","execution_count":null,"metadata":{},"outputs":[]},{"cell_type":"code","source":"hex_scheduled = _hex_json.loads(\"false\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_user_email = _hex_json.loads(\"\\\"example-user@example.com\\\"\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_user_attributes = _hex_json.loads(\"{}\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_run_context = _hex_json.loads(\"\\\"logic\\\"\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_timezone = _hex_json.loads(\"\\\"UTC\\\"\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_project_id = _hex_json.loads(\"\\\"019d94fd-194f-7000-9b72-83aadb9c7e6c\\\"\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_project_name = _hex_json.loads(\"\\\"Stock Dash\\\"\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_status = _hex_json.loads(\"\\\"\\\"\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_categories = _hex_json.loads(\"[]\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"hex_color_palette = _hex_json.loads(\"[\\\"#4C78A8\\\",\\\"#F58518\\\",\\\"#E45756\\\",\\\"#72B7B2\\\",\\\"#54A24B\\\",\\\"#EECA3B\\\",\\\"#B279A2\\\",\\\"#FF9DA6\\\",\\\"#9D755D\\\",\\\"#BAB0AC\\\"]\")","outputs":[],"execution_count":null,"metadata":{}},{"cell_type":"code","source":"# import jinja2\n# raw_query = \"\"\"\n#     select * from \"enhanced_analysis_20260428_1911.csv\";\n# \"\"\"\n# sql_query = jinja2.Template(raw_query).render(vars())","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"code","source":"\nimport pandas as pd\nimport numpy as np\n\ndf = stock_report_20260415_194600.copy()\n\ndef pct_to_float(s):\n    if pd.isna(s) or s in ('None', '', 'nan'):\n        return np.nan\n    return float(str(s).replace('%', '').replace(',', ''))\n\ndef money_to_float(s):\n    if pd.isna(s) or s in ('None', '', 'nan'):\n        return np.nan\n    return float(str(s).replace(',', '').replace('$', ''))\n\npct_cols = ['1D Change (%)', 'Portfolio %', 'pct From High',\n            'TSMOM 5d', 'TSMOM 10d', 'TSMOM 20d', 'TSMOM 60d', 'TSMOM 126d', 'TSMOM 252d',\n            '% Above 50MA', '% Above 200MA']\nmoney_cols = ['Current Value', 'Cost Value ($)', 'Delta']\n\nfor c in pct_cols:\n    if c in df.columns:\n        df[c] = df[c].apply(pct_to_float)\n\nfor c in money_cols:\n    if c in df.columns:\n        df[c] = df[c].apply(money_to_float)\n\nif 'Peak Volume' in df.columns:\n    df['Peak Volume'] = df['Peak Volume'].apply(money_to_float)\n\ndf['Signal_Category'] = df['Signal'].map({\n    'STRONG_BUY': 'Buy',\n    'BUY': 'Buy',\n    'HOLD_WATCH_FOR_BUY': 'Watch',\n    'HOLD_NEUTRAL': 'Hold',\n    'HOLD_WATCH_FOR_SELL': 'Watch',\n    'SELL': 'Sell',\n    'STRONG_SELL': 'Sell',\n})\n\ndf['P&L %'] = np.where(df['Cost Value ($)'] > 0, \n                        (df['Delta'] / df['Cost Value ($)']) * 100, 0)\n\ntotal_value = df['Current Value'].sum()\ntotal_cost = df['Cost Value ($)'].sum()\ntotal_delta = df['Delta'].sum()\ntotal_pnl_pct = (total_delta / total_cost * 100) if total_cost > 0 else 0\nnum_positions = len(df)\nnum_winners = (df['Delta'] > 0).sum()\nwin_rate = num_winners / num_positions * 100\n\nportfolio = df\n","metadata":{},"execution_count":null,"outputs":[]},{"cell_type":"code","source":"# import jinja2\n# raw_query = \"\"\"\n#     SELECT\n#         \"Stock\",\n#         \"Signal\",\n#         \"Action\",\n#         \"Net Score\",\n#         \"Current Price\",\n#         \"Current Value\",\n#         \"Delta\",\n#         \"P&L %\",\n#         \"TSMOM Align\",\n#         \"MA Position\",\n#         \"Z-Score\",\n#         \"Std Devs\",\n#         \"pct From High\",\n#         \"Warnings\"\n#     FROM portfolio\n#     ORDER BY \"Net Score\" ASC, \"P&L %\" ASC\n#     \n# \"\"\"\n# sql_query = jinja2.Template(raw_query).render(vars())","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"code","source":"\ntop15 = portfolio.nlargest(15, 'Delta')\nbottom15 = portfolio.nsmallest(15, 'Delta')\npnl_extremes = pd.concat([top15, bottom15]).drop_duplicates(subset='Stock')\npnl_extremes['bar_color'] = pnl_extremes['Delta'].apply(lambda x: 'Gain' if x >= 0 else 'Loss')\n","metadata":{},"execution_count":null,"outputs":[]},{"cell_type":"code","source":"df[['Stock', 'Current Price', 'Volume', '1D Change (%)'\n, 'TSMOM 5d', 'TSMOM 10d', 'TSMOM 20d', 'TSMOM 60d', 'TSMOM 126d', 'TSMOM 252d'\n,'Dist Std Devs', 'Vol vs Dist Avg', 'Days in Dist', 'pct From High']]","metadata":{},"execution_count":null,"outputs":[{"data":{"application/vnd.hex.export+parquet":{"success":true,"exportKey":"019d94fc-3473-7000-ae11-c562bc42b2dc/019d94fd-194f-7000-9b72-83aadb9c7e6c/exports/019dd703-4b1f-7000-a6dd-a9132062cd48"},"text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>Stock</th>\n      <th>Current Price</th>\n      <th>Volume</th>\n      <th>1D Change (%)</th>\n      <th>TSMOM 5d</th>\n      <th>TSMOM 10d</th>\n      <th>TSMOM 20d</th>\n      <th>TSMOM 60d</th>\n      <th>TSMOM 126d</th>\n      <th>TSMOM 252d</th>\n      <th>Dist Std Devs</th>\n      <th>Vol vs Dist Avg</th>\n      <th>Days in Dist</th>\n      <th>pct From High</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>SG</td>\n      <td>7</td>\n      <td>3</td>\n     