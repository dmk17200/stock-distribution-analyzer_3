   <td>-2.6</td>\n      <td>13.8</td>\n      <td>54.8</td>\n      <td>94.9</td>\n      <td>72.9</td>\n      <td>161.7</td>\n      <td>11.03</td>\n      <td>1.69</td>\n      <td>317</td>\n      <td>-7.5</td>\n    </tr>\n    <tr>\n      <th>142</th>\n      <td>WAB</td>\n      <td>263</td>\n      <td>1</td>\n      <td>-1.5</td>\n      <td>0.6</td>\n      <td>2.3</td>\n      <td>5.3</td>\n      <td>12.8</td>\n      <td>31.7</td>\n      <td>44.3</td>\n      <td>13.46</td>\n      <td>0.45</td>\n      <td>151</td>\n      <td>-2.9</td>\n    </tr>\n    <tr>\n      <th>143</th>\n      <td>MPWR</td>\n      <td>1504</td>\n      <td>1</td>\n      <td>-5.3</td>\n      <td>-1.2</td>\n      <td>11.2</td>\n      <td>37.6</td>\n      <td>28.5</td>\n      <td>36.6</td>\n      <td>159.0</td>\n      <td>13.57</td>\n      <td>0.99</td>\n      <td>20</td>\n      <td>-7.8</td>\n    </tr>\n    <tr>\n      <th>144</th>\n      <td>AMD</td>\n      <td>323</td>\n      <td>42</td>\n      <td>-3.4</td>\n      <td>6.5</td>\n      <td>25.2</td>\n      <td>58.9</td>\n      <td>31.2</td>\n      <td>24.5</td>\n      <td>235.3</td>\n      <td>14.79</td>\n      <td>1.03</td>\n      <td>82</td>\n      <td>-7.1</td>\n    </tr>\n    <tr>\n      <th>145</th>\n      <td>LRCX</td>\n      <td>251</td>\n      <td>11</td>\n      <td>-3.2</td>\n      <td>-5.4</td>\n      <td>-5.3</td>\n      <td>17.6</td>\n      <td>5.9</td>\n      <td>60.6</td>\n      <td>253.6</td>\n      <td>26.62</td>\n      <td>1.09</td>\n      <td>117</td>\n      <td>-7.8</td>\n    </tr>\n  </tbody>\n</table>\n<p>146 rows × 14 columns</p>\n</div>"},"execution_count":null,"metadata":{},"output_type":"execute_result"}]},{"cell_type":"code","source":"\nimport pandas as pd\nimport numpy as np\n\np = portfolio.copy()\n\nfeatures = ['Dist Std Devs', 'Vol vs Dist Avg', 'Days in Dist',\n            'TSMOM 5d', 'TSMOM 10d', 'TSMOM 20d', 'TSMOM 60d', 'TSMOM 126d', 'TSMOM 252d']\noutcomes = ['1D Change (%)', 'TSMOM 5d', 'TSMOM 10d', 'TSMOM 20d']\n\n# --- 1. Correlation matrix ---\ncorr_cols = ['Dist Std Devs', 'Vol vs Dist Avg', 'Days in Dist',\n             'TSMOM 5d', 'TSMOM 10d', 'TSMOM 20d', 'TSMOM 60d', 'TSMOM 126d', 'TSMOM 252d',\n             '1D Change (%)', 'P&L %', 'Z-Score', 'Net Score']\ncorr_matrix = p[corr_cols].corr()\n\nprint(\"=\" * 80)\nprint(\"1. CORRELATION MATRIX (key pairs)\")\nprint(\"=\" * 80)\nkey_pairs = [\n    ('Dist Std Devs', 'TSMOM 20d'), ('Dist Std Devs', 'TSMOM 60d'), \n    ('Dist Std Devs', 'TSMOM 126d'), ('Dist Std Devs', 'TSMOM 252d'),\n    ('Dist Std Devs', 'Net Score'), ('Dist Std Devs', 'P&L %'),\n    ('Vol vs Dist Avg', '1D Change (%)'), ('Vol vs Dist Avg', 'TSMOM 5d'),\n    ('Days in Dist', 'Dist Std Devs'), ('Days in Dist', 'TSMOM 252d'),\n    ('Days in Dist', 'P&L %'),\n    ('TSMOM 20d', 'TSMOM 5d'), ('TSMOM 60d', 'TSMOM 20d'),\n    ('TSMOM 126d', 'TSMOM 20d'), ('TSMOM 252d', 'Net Score'),\n]\nfor a, b in key_pairs:\n    r = corr_matrix.loc[a, b]\n    print(f\"  {a:20s} × {b:20s} = {r:+.3f}\")\n\n# --- 2. Bucket Dist Std Devs and see average returns ---\nprint(\"\\n\" + \"=\" * 80)\nprint(\"2. RETURNS BY 'DIST STD DEVS' BUCKET\")\nprint(\"=\" * 80)\np['Dist_Bucket'] = pd.cut(p['Dist Std Devs'], bins=[-20, -3, -1, 0, 1, 3, 20],\n                           labels=['< -3σ', '-3 to -1σ', '-1 to 0σ', '0 to 1σ', '1 to 3σ', '> 3σ'])\nbucket_stats = p.groupby('Dist_Bucket', observed=True).agg(\n    count=('Stock', 'count'),\n    avg_1d=('1D Change (%)', 'mean'),\n    avg_5d=('TSMOM 5d', 'mean'),\n    avg_20d=('TSMOM 20d', 'mean'),\n    avg_60d=('TSMOM 60d', 'mean'),\n    avg_252d=('TSMOM 252d', 'mean'),\n    pct_positive_5d=('TSMOM 5d', lambda x: (x > 0).mean() * 100),\n    avg_net_score=('Net Score', 'mean'),\n).round(2)\nprint(bucket_stats.to_string())\n\n# --- 3. Vol vs Dist Avg buckets ---\nprint(\"\\n\" + \"=\" * 80)\nprint(\"3. RETURNS BY 'VOL VS DIST AVG' BUCKET\")\nprint(\"=\" * 80)\np['Vol_Bucket'] = pd.cut(p['Vol vs Dist Avg'], bins=[0, 0.5, 0.8, 1.0, 1.5, 100],\n                          labels=['< 0.5x', '0.5-0.8x', '0.8-1.0x', '1.0-1.5x', '> 1.5x'])\nvol_stats = p.groupby('Vol_Bucket', observed=True).agg(\n    count=('Stock', 'count'),\n    avg_1d=('1D Change (%)', 'mean'),\n    avg_5d=('TSMOM 5d', 'mean'),\n    avg_20d=('TSMOM 20d', 'mean'),\n    avg_net_score=('Net Score', 'mean'),\n    pct_positive_5d=('TSMOM 5d', lambda x: (x > 0).mean() * 100),\n).round(2)\nprint(vol_stats.to_string())\n\n# --- 4. Days in Dist buckets ---\nprint(\"\\n\" + \"=\" * 80)\nprint(\"4. RETURNS BY 'DAYS IN DIST' BUCKET\")\nprint(\"=\" * 80)\np['Days_Bucket'] = pd.cut(p['Days in Dist'], bins=[0, 50, 100, 200, 500],\n                           labels=['< 50d', '50-100d', '100-200d', '> 200d'])\ndays_stats = p.groupby('Days_Bucket', observed=True).agg(\n    count=('Stock', 'count'),\n    avg_dist_std=('Dist Std Devs', 'mean'),\n    avg_5d=('TSMOM 5d', 'mean'),\n    avg_20d=('TSMOM 20d', 'mean'),\n    avg_252d=('TSMOM 252d', 'mean'),\n    pct_positive_5d=('TSMOM 5d', lambda x: (x > 0).mean() * 100),\n).round(2)\nprint(days_stats.to_string())\n\n# --- 5. TSMOM alignment as predictor ---\nprint(\"\\n\" + \"=\" * 80)\nprint(\"5. TSMOM ALIGNMENT AS PREDICTOR OF SHORT-TERM RETURNS\")\nprint(\"=\" * 80)\nalign_stats = p.groupby('TSMOM Align', observed=True).agg(\n    count=('Stock', 'count'),\n    avg_1d=('1D Change (%)', 'mean'),\n    avg_5d=('TSMOM 5d', 'mean'),\n    avg_net_score=('Net Score', 'mean'),\n    avg_dist_std=('Dist Std Devs', 'mean'),\n    pct_positive_1d=('1D Change (%)', lambda x: (x > 0).mean() * 100),\n).round(2)\nprint(align_stats.to_string())\n\n# --- 6. Composite signal test ---\nprint(\"\\n\" + \"=\" * 80)\nprint(\"6. COMPOSITE SIGNAL: Dist Std Devs < -1 AND TSMOM 20d > 0 (mean-reversion + momentum)\")\nprint(\"=\" * 80)\ncombo = p[(p['Dist Std Devs'] < -1) & (p['TSMOM 20d'] > 0)]\nanti = p[(p['Dist Std Devs'] < -1) & (p['TSMOM 20d'] <= 0)]\nprint(f\"  Stocks matching (below dist + positive 20d momentum): {len(combo)}\")\nprint(f\"    Avg 1D Change: {combo['1D Change (%)'].mean():.2f}%  |  Avg 5D: {combo['TSMOM 5d'].mean():.2f}%\")\nprint(f\"    % positive 1D: {(combo['1D Change (%)'] > 0).mean()*100:.1f}%\")\nprint(f\"  Stocks NOT matching (below dist + negative 20d):       {len(anti)}\")\nprint(f\"    Avg 1D Change: {anti['1D Change (%)'].mean():.2f}%  |  Avg 5D: {anti['TSMOM 5d'].mean():.2f}%\")\nprint(f\"    % positive 1D: {(anti['1D Change (%)'] > 0).mean()*100:.1f}%\")\n\n# --- 7. Rank correlation (manual Spearman via rank + Pearson) ---\nprint(\"\\n\" + \"=\" * 80)\nprint(\"7. RANK CORRELATIONS WITH 1D CHANGE (%)\")\nprint(\"=\" * 80)\nfor col in features:\n    subset = p[[col, '1D Change (%)']].dropna()\n    r = subset[col].rank().corr(subset['1D Change (%)'].rank())\n    print(f\"  {col:20s}  ρ = {r:+.3f}\")\n\nindicator_analysis = p\n","metadata":{},"execution_count":null,"outputs":[{"data":{"text/plain":"================================================================================\n1. CORRELATION MATRIX (key pairs)\n================================================================================\n  Dist Std Devs        × TSMOM 20d            = +0.291\n  Dist Std Devs        × TSMOM 60d            = +0.415\n  Dist Std Devs        × TSMOM 126d           = +0.467\n  Dist Std Devs        × TSMOM 252d           = +0.279\n  Dist Std Devs        × Net Score            = +0.507\n  Dist Std Devs        × P&L %                = +0.022\n  Vol vs Dist Avg      × 1D Change (%)        = -0.154\n  Vol vs Dist Avg      × TSMOM 5d             = +0.038\n  Days in Dist         × Dist Std Devs        = -0.135\n  Days in Dist         × TSMOM 252d           = -0.133\n  Days in Dist         × P&L %                = -0.131\n  TSMOM 20d            × TSMOM 5d             = -0.044\n  TSMOM 60d            × TSMOM 20d            = +0.515\n  TSMOM 126d           × TSMOM 20d            = +0.127\n  TSMOM 252d           × Net Score            = +0.372\n\n================================================================================\n2. RETURNS BY 'DIST STD DEVS' BUCKET\n================================================================================\n             count  avg_1d  avg_5d  avg_20d  avg_60d  avg_252d  pct_positive_5d  avg_net_score\nDist_Bucket                                                                                   \n< -3σ            2   -2.85   -7.45    33.15    14.40     43.05             0.00           2.00\n-3 to -1σ       28   -0.59   -3.18     6.30    -7.73     -4.33            10.71          -1.43\n-1 to 0σ        24   -1.54   -4.19     7.98    -7.78     13.19            12.50          -1.21\n0 to 1σ         27   -1.43   -3.69    11.74    -0.27    101.64            18.52           0.81\n1 to 3σ         40   -1.18   -2.12     9.65     7.84     57.14            42.50           3.65\n> 3σ            24   -2.06    1.14    21.87    25.18    131.12            62.50           5.58\n\n================================================================================\n3. RETURNS BY 'VOL VS DIST AVG' BUCKET\n================================================================================\n            count  avg_1d  avg_5d  avg_20d  avg_net_score  pct_positive_5d\nVol_Bucket                                                                \n< 0.5x         20   -1.11   -4.88     8.50           0.65            15.00\n0.5-0.8x       51   -0.64   -1.69     8.70           1.84            35.29\n0.8-1.0x       36   -1.58   -2.30    13.48           1.67            30.56\n1.0-1.5x       30   -2.26   -2.95    12.58           1.20            23.33\n> 1.5x          9   -2.04   -1.29    22.58           4.44            44.44\n\n================================================================================\n4. RETURNS BY 'DAYS IN DIST' BUCKET\n================================================================================\n             count  avg_dist_std  avg_5d  avg_20d  avg_252d  pct_positive_5d\nDays_Bucket                                                                 \n< 50d           20          1.68   -1.30    15.21    110.16            40.00\n50-100d         34          1.44   -3.79     8.78     61.31            23.53\n100-200d        31          2.23   -2.91    11.05     52.39            25.81\n> 200d          61          0.90   -1.99    12.04     44.93            31.15\n\n================================================================================\n5. TSMOM ALIGNMENT AS PREDICTOR OF SHORT-TERM RETURNS\n================================================================================\n              count  avg_1d  avg_5d  avg_net_score  avg_dist_std  pct_positive_1d\nTSMOM Align                                                                      \nFULL_BEAR         7   -0.84   -5.27          -6.00         -1.45            28.57\nFULL_BULL        26   -0.95    2.63           6.00          4.46            26.92\nLEANING_BEAR     48   -1.36   -5.06          -1.88         -0.15            25.00\nLEANING_BULL     45   -1.44   -2.04           4.47          2.46            24.44\nMIXED            20   -1.82   -3.16           0.90         -0.13            30.00\n\n================================================================================\n6. COMPOSITE SIGNAL: Dist Std Devs < -1 AND TSMOM 20d > 0 (mean-reversion + momentum)\n================================================================================\n  Stocks matching (below dist + positive 20d momentum): 19\n    Avg 1D Change: -0.80%  |  Avg 5D: -3.03%\n    % positive 1D: 31.6%\n  Stocks NOT matching (below dist + negative 20d):       10\n    Avg 1D Change: -0.66%  |  Avg 5D: -4.60%\n    % positive 1D: 30.0%\n\n================================================================================\n7. RANK CORRELATIONS WITH 1D CHANGE (%)\n================================================================================\n  Dist Std Devs         ρ = -0.117\n  Vol vs Dist Avg       ρ = -0.242\n  Days in Dist          ρ = +0.072\n  TSMOM 5d              ρ = +0.436\n  TSMOM 10d             ρ = +0.087\n  TSMOM 20d             ρ = -0.429\n  TSMOM 60d             ρ = -0.117\n  TSMOM 126d            ρ = -0.127\n  TSMOM 252d            ρ = -0.471\n"},"execution_count":null,"metadata":{},"output_type":"execute_result"}]},{"cell_type":"code","source":"# import jinja2\n# raw_query = \"\"\"\n#     SELECT\n#         \"Dist_Bucket\",\n#         \"Horizon\",\n#         AVG(\"Return\") AS avg_return\n#     FROM (\n#         SELECT\n#             \"Dist_Bucket\",\n#             '5d' AS \"Horizon\",\n#             \"TSMOM 5d\" AS \"Return\"\n#         FROM indicator_analysis\n#         UNION ALL\n#         SELECT\n#             \"Dist_Bucket\",\n#             '20d',\n#             \"TSMOM 20d\"\n#         FROM indicator_analysis\n#         UNION ALL\n#         SELECT\n#             \"Dist_Bucket\",\n#             '60d',\n#             \"TSMOM 60d\"\n#         FROM indicator_analysis\n#         UNION ALL\n#         SELECT\n#             \"Dist_Bucket\",\n#             '252d',\n#             \"TSMOM 252d\"\n#         FROM indicator_analysis\n#     )\n#     GROUP BY \"Dist_Bucket\", \"Horizon\"\n#     \n# \"\"\"\n# sql_query = jinja2.Template(raw_query).render(vars())","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"code","source":"\nconditions = [\n    # High Vol + High Price + dropping = distribution (breakdown)\n    (df['Vol vs Dist Avg'] >= 1) & (df['Dist Std Devs'] > 1) & (df['1D Change (%)'] < 0),\n    # High Vol + High Price + rising = genuine breakout\n    (df['Vol vs Dist Avg'] >= 1) & (df['Dist Std Devs'] > 1),\n    # High Vol + Low Price + rising = reversal (breakout)\n    (df['Vol vs Dist Avg'] >= 1) & (df['Dist Std Devs'] < -1) & (df['1D Change (%)'] > 0),\n    # High Vol + Low Price + dropping = breakdown\n    (df['Vol vs Dist Avg'] >= 1) & (df['Dist Std Devs'] < -1),\n    # High Vol + Neutral Price = support\n    (df['Vol vs Dist Avg'] >= 1) & (df['Dist Std Devs'].between(-1, 1)),\n    # Low Vol + High Price = exploration\n    (df['Vol vs Dist Avg'] < 1) & (df['Dist Std Devs'] > 1),\n    # Low Vol + Low/Neutral Price = noise\n    (df['Vol vs Dist Avg'] < 1) & (df['Dist Std Devs'] <= 1),\n]\nlabels = [\n    'Breakdown (High Vol + Low Price)',\n    'Breakout (High Vol + High Price)',\n    'Breakout (High Vol + High Price)',\n    'Breakdown (High Vol + Low Price)',\n    'Support (High Vol + No Price)',\n    'Exploration (Low Vol + High Price)',\n    'Noise (Low Vol + No Price)',\n]\ndf['quadrant'] = np.select(conditions, labels, default='Unclassified')\n\ndf['tsmom_signal'] = np.where(\n    (df['TSMOM 5d'] > 0) & (df['TSMOM 10d'] > 0), 'Both Positive',\n    np.where(\n        (df['TSMOM 5d'] < 0) & (df['TSMOM 10d'] < 0), 'Both Negative',\n        'Mixed'\n    )\n)\n","metadata":{},"execution_count":null,"outputs":[]},{"cell_type":"code","source":"\nimport plotly.graph_objects as go\n\ncolor_map = {'Both Positive': '#4CAF50', 'Both Negative': '#E45756', 'Mixed': '#EECA3B'}\n\nfig = go.Figure()\n\nfor signal, color in color_map.items():\n    mask = df['tsmom_signal'] == signal\n    sub = df[mask]\n    fig.add_trace(go.Scatter(\n        x=sub['Dist Std Devs'], y=sub['Vol vs Dist Avg'],\n        mode='markers',\n        marker=dict(color=color, size=8, opacity=0.75, line=dict(width=0.5, color='#444')),\n        name=signal,\n        hovertemplate='<b>%{customdata[0]}</b><br>Dist Std Devs: %{x:.2f}<br>Vol vs Dist Avg: %{y:.2f}<br>Quadrant: %{customdata[1]}<extra></extra>',\n        customdata=sub[['Stock', 'quadrant']].values,\n    ))\n\nfig.add_hline(y=1, line_dash='dash', line_color='#737373', line_width=1,\n              annotation_text='Vol Avg = 1x', annotation_position='top left',\n              annotation_font_size=11, annotation_font_color='#737373')\nfig.add_vline(x=-1, line_dash='dash', line_color='#737373', line_width=1,\n              annotation_text='-1σ', annotation_position='top left',\n              annotation_font_size=11, annotation_font_color='#737373')\nfig.add_vline(x=1, line_dash='dash', line_color='#737373', line_width=1,\n              annotation_text='+1σ', annotation_position='top right',\n              annotation_font_size=11, annotation_font_color='#737373')\n\nx_max = df['Dist Std Devs'].max()\ny_max = df['Vol vs Dist Avg'].max()\n\nquadrant_labels = [\n    dict(text='Breakout<br>(High Vol + High Price)', x=(1 + x_max) / 2, y=(1 + y_max) / 2),\n    dict(text='Breakdown<br>(High Vol + Low Price)', x=(-1 + df['Dist Std Devs'].min()) / 2, y=(1 + y_max) / 2),\n    dict(text='Support<br>(High Vol + No Price)', x=0, y=(1 + y_max) / 2),\n    dict(text='Exploration<br>(Low Vol + High Price)', x=(1 + x_max) / 2, y=1 * 0.5),\n    dict(text='Noise<br>(Low Vol + No Price)', x=0, y=1 * 0.5),\n]\n\nfor q in quadrant_labels:\n    fig.add_annotation(\n        x=q['x'], y=q['y'], text=q['text'],\n        showarrow=False, font=dict(size=16, color='rgba(150,150,150,0.45)'),\n        xanchor='center', yanchor='middle',\n    )\n\nfig.update_layout(\n    title=dict(text='Stocks by Statistical Extension & Relative Volume', font=dict(size=16)),\n    xaxis=dict(title='Dist Std Devs (Price Extension)', gridcolor='#eee', gridwidth=1,\n               zeroline=False),\n    yaxis=dict(title='Vol vs Distribution Avg (Relative Volume)', gridcolor='#eee', gridwidth=1,\n               zeroline=False),\n    legend=dict(title='tsmom_signal', x=1.02, y=1, xanchor='left'),\n    plot_bgcolor='white',\n    margin=dict(l=60, r=140, t=60, b=60),\n    height=600,\n)\n\nfig.show()\n","metadata":{},"execution_count":null,"outputs":[{"data":{"application/vnd.plotly.v1+json":{"data":[{"customdata":[["PG","Exploration (Low Vol + High Price)"],["GWW","Noise (Low Vol + No Price)"],["ELV","Noise (Low Vol + No Price)"],["QCOM","Support (High Vol + No Price)"],["FSLR","Noise (Low Vol + No Price)"],["XOM","Noise (Low Vol + No Price)"],["HROW","Noise (Low Vol + No Price)"],["WFC","Noise (Low Vol + No Price)"],["OSCR","Noise (Low Vol + No Price)"],["NDSN","Exploration (Low Vol + High Price)"],["PM","Exploration (Low Vol + High Price)"],["DUOL","Exploration (Low Vol + High Price)"],["OXY","Exploration (Low Vol + High Price)"],["VZ","Breakout (High Vol + High Price)"],["IWD","Exploration (Low Vol + High Price)"],["KO","Breakout (High Vol + High Price)"],["AFL","Exploration (Low Vol + High Price)"],["CAT","Exploration (Low Vol + High Price)"],["TT","Exploration (Low Vol + High Price)"],["TSM","Breakdown (High Vol + Low Price)"],["SDCI","Breakout (High Vol + High Price)"],["AMZN","Breakdown (High Vol + Low Price)"],["VOO","Exploration (Low Vol + High Price)"],["JCI","Exploration (Low Vol + High Price)"],["NEE","Exploration (Low Vol + High Price)"],["DTE","Exploration (Low Vol + High Price)"],["FLEX","Breakdown (High Vol + Low Price)"],["ARM","Breakdown (High Vol + Low Price)"],["PWR","Breakdown (High Vol + Low Price)"],["NVDA","Breakdown (High Vol + Low Price)"],["HXL","Exploration (Low Vol + High Price)"],["ADI","Exploration (Low Vol + High Price)"],["GOOGL","Exploration (Low Vol + High Price)"],["MU","Breakdown (High Vol + Low Price)"],["GOOG","Exploration (Low Vol + High Price)"],["UNP","Exploration (Low Vol + High Price)"],["WAB","Exploration (Low Vol + High Price)"],["AMD","Breakdown (High Vol + Low Price)"]],"hovertemplate":"<b>%{customdata[0]}</b><br>Dist Std Devs: %{x:.2f}<br>Vol vs Dist Avg: %{y:.2f}<br>Quadrant: %{customdata[1]}<extra></extra>","marker":{"color":"#4CAF50","line":{"color":"#444","width":0.5},"opacity":0.75,"size":8},"mode":"markers","name":"Both Positive","x":[1.53,-1.19,-1.1,-0.44,-0.12,0.04,0.04,0.39,0.65,1.19,1.42,1.46,1.51,1.78,1.99,2.07,2.27,2.52,2.85,2.89,2.93,2.96,2.98,3.3,4.03,4.09,4.1,4.14,4.35,4.59,4.74,4.76,4.95,4.99,6.05,10.09,13.46,14.79],"y":[0.79,0.74,0.73,2.62,0.61,0.67,0.82,0.9,0.86,0.85,0.52,0.61,0.9,1.25,0.31,1.93,0.61,0.68,0.94,1.03,1.59,1,0.58,0.57,0.53,0.87,1.07,1.71,1.27,1.02,0.85,0.96,0.8,1.07,0.77,0.6,0.45,1.03],"type":"scatter"},{"customdata":[["CRWV","Breakdown (High Vol + Low Price)"],["PIN